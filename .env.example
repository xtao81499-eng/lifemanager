# Google Calendar API
GOOGLE_CALENDAR_ID=primary
# 可以指定多个日历ID，逗号分隔
# GOOGLE_CALENDAR_ID=primary,work@group.calendar.google.com

# Google Drive — 反思文档文件夹 ID
GDRIVE_REFLECTION_FOLDER_ID=

# App Config
TIMEZONE=Asia/Shanghai

# 代理（访问 Google 需要）。默认 http://127.0.0.1:17890，
# 换了 VPN/Clash 端口就在这里改，不用动代码。留空则不走代理。
# LIFEMANAGER_PROXY=http://127.0.0.1:17890
